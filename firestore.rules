rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "hamimxz32@gmail.com");
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Rosters Rules
    match /rosters/{rosterId} {
      allow read: if resource.data.status == 'approved' || isAdmin() || (isAuthenticated() && resource.data.authorUid == request.auth.uid);
      allow create: if isAuthenticated() && 
        (request.resource.data.status == 'pending' || (request.resource.data.status == 'approved' && isAdmin())) && 
        request.resource.data.authorUid == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() && (
        resource.data.authorUid == request.auth.uid ||
        (resource.data.status == 'approved' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']))
      ));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.authorUid == request.auth.uid);
    }

    // Gallery Rules
    match /gallery/{itemId} {
      allow read: if resource.data.status == 'approved' || isAdmin() || (isAuthenticated() && resource.data.authorUid == request.auth.uid);
      allow create: if isAuthenticated() && 
        (request.resource.data.status == 'pending' || (request.resource.data.status == 'approved' && isAdmin())) && 
        request.resource.data.authorUid == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() && (
        resource.data.authorUid == request.auth.uid ||
        (resource.data.status == 'approved' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']))
      ));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.authorUid == request.auth.uid);
    }

    // Comments Rules
    match /comments/{commentId} {
      allow read: if resource.data.status == 'approved' || isAdmin() || (isAuthenticated() && resource.data.authorUid == request.auth.uid);
      allow create: if isAuthenticated() && 
        request.resource.data.status == 'pending' && 
        request.resource.data.authorUid == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.authorUid == request.auth.uid);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.authorUid == request.auth.uid);
    }

    // Friend Requests Rules
    match /friendRequests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.fromUid == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.toUid == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));
      allow delete: if isAuthenticated() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    }

    // Messages Rules
    match /messages/{messageId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants && request.resource.data.senderUid == request.auth.uid;
      allow update, delete: if false;
    }

    // Recruitment Rules
    match /recruitment/{postId} {
      allow read: if resource.data.status == 'approved' || isAdmin() || (isAuthenticated() && resource.data.authorUid == request.auth.uid);
      allow create: if isAuthenticated() && 
        (request.resource.data.status == 'pending' || (request.resource.data.status == 'approved' && isAdmin())) && 
        request.resource.data.authorUid == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() && (
        resource.data.authorUid == request.auth.uid ||
        (resource.data.status == 'approved' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']))
      ));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.authorUid == request.auth.uid);
    }

    // Community Message Board Rules
    match /messageBoard/{msgId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reports', 'reactions']));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.authorUid == request.auth.uid);
    }

    // Team Challenges Rules
    match /challenges/{challengeId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.challengerUid || request.auth.uid == resource.data.targetUid);
      allow create: if isAuthenticated() && request.resource.data.challengerUid == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.targetUid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));
      allow delete: if isAdmin();
    }

    // Esports Pages Rules
    match /esportsPages/{pageId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
        (request.resource.data.status == 'pending' || (request.resource.data.status == 'approved' && isAdmin())) && 
        request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Top Teams Rules
    match /topTeams/{teamId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']));
    }

    // Champions Rules
    match /champions/{championId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Hall of Fame Rules
    match /hallOfFame/{entryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Page Upgrade Requests Rules
    match /upgradeRequests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.authorUid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Global Group Chat Rules
    match /groupChat/{msgId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Users Rules
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
      // Ensure email is not modified by others and only readable by owner/admin
      // Note: Since we allow public read for username search, email is technically visible if included in document.
      // To be strictly secure, we should move email to a private subcollection.
      // For now, we'll keep it as is to support login by username.
    }

    // Visits Rules
    match /visits/{visitId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Settings Rules
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
